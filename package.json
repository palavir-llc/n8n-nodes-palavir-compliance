{
  "name": "n8n-nodes-palavir-compliance",
  "version": "0.1.0",
  "description": "n8n community node for Palavir Compliance — screen entities against LEIE, OFAC SDN, and SAM.gov in one call.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "compliance",
    "ofac",
    "sanctions",
    "leie",
    "sam",
    "kyc",
    "palavir"
  ],
  "license": "MIT",
  "author": "Palavir LLC <josh@palavir.co>",
  "homepage": "https://palavir.co/exclusion-screening",
  "repository": {
    "type": "git",
    "url": "https://github.com/palavir-llc/n8n-nodes-palavir-compliance"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PalavirComplianceApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PalavirCompliance/PalavirCompliance.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "n8n-workflow": "^1.0.0",
    "typescript": "^5.5.0"
  }
}
